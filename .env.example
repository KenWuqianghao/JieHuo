# Canonical site URL for Open Graph / Twitter cards
NEXT_PUBLIC_SITE_URL=https://jiehuo.vercel.app

# Hugging Face model repo (see ml/09_upload_hf.py)
NEXT_PUBLIC_MODEL_REPO=KenWu/multilingual-query-router
JIEHUO_MODEL_REPO=KenWu/multilingual-query-router
JIEHUO_MODEL_TIMEOUT_MS=25000
JIEHUO_ROUTER_MODE=heuristic

# Optional: server /api/route?mode=model can call HF Inference API (same trained model).
# Create a read token at https://huggingface.co/settings/tokens
HF_TOKEN=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM labeling (optional — for ml/02 and ml/04)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=openai/gpt-4.1-mini
ANTHROPIC_API_KEY=
