# Canonical site URL for Open Graph / Twitter cards
NEXT_PUBLIC_SITE_URL=https://jiehuo.vercel.app

# Hugging Face model repo for production (see ml/09_upload_hf.py)
NEXT_PUBLIC_MODEL_REPO=

# Server-side address-bar router (see /search?q=%s)
JIEHUO_MODEL_REPO=KenWu/multilingual-query-router
JIEHUO_MODEL_TIMEOUT_MS=2500
JIEHUO_ROUTER_MODE=model

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM labeling (optional — for ml/02 and ml/04)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=openai/gpt-4.1-mini
ANTHROPIC_API_KEY=
